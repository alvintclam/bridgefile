{
  "name": "bridgefile",
  "version": "0.1.0",
  "description": "A cross-platform file transfer client that supports SFTP and controlled S3 access without requiring full bucket browsing.",
  "main": "dist/main/main.js",
  "bin": {
    "bridgefile": "dist/cli/cli.js"
  },
  "scripts": {
    "dev": "npm run build:main && npm run build:preload && concurrently -n vite,electron -c blue,green \"vite --config vite.config.ts\" \"wait-on http://localhost:5173 && VITE_DEV_SERVER_URL=http://localhost:5173 electron .\"",
    "build:main": "tsc -p tsconfig.main.json",
    "build:preload": "tsc -p tsconfig.preload.json",
    "build:renderer": "vite build --config vite.config.ts",
    "build:cli": "tsc -p tsconfig.cli.json",
    "build": "npm run build:main && npm run build:preload && npm run build:renderer",
    "cli": "node dist/cli/cli.js",
    "test": "tsc -p tsconfig.test.json && node --test dist-test/test/transfer-scheduler.test.js dist-test/test/transfer-rate-limit.test.js dist-test/test/connection-profile-ui.test.js",
    "pack": "npm run build && electron-builder --dir",
    "dist": "npm run build && electron-builder",
    "dist:win": "npm run build && electron-builder --win",
    "dist:mac": "npm run build && electron-builder --mac",
    "dist:linux": "npm run build && electron-builder --linux",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "sftp",
    "s3",
    "file-transfer",
    "electron",
    "ftp-client",
    "cross-platform",
    "s3-single-bucket"
  ],
  "author": "BridgeFile <hello@bridgefile.io>",
  "license": "BSL-1.1",
  "homepage": "https://bridgefile.io",
  "repository": {
    "type": "git",
    "url": "https://github.com/bridgefile/bridgefile.git"
  },
  "bugs": {
    "url": "https://github.com/bridgefile/bridgefile/issues"
  },
  "type": "commonjs",
  "build": {
    "appId": "com.bridgefile.app",
    "productName": "BridgeFile",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*"
    ],
    "win": {
      "target": [
        "nsis",
        "portable"
      ],
      "icon": "assets/icon.ico"
    },
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "icon": "assets/icon.icns",
      "category": "public.app-category.utilities",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.plist",
      "notarize": false
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "icon": "assets/icon.png",
      "category": "Utility"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1027.0",
    "@aws-sdk/lib-storage": "^3.1029.0",
    "basic-ftp": "^5.3.0",
    "keytar": "^7.9.0",
    "ssh2": "^1.17.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/ssh2": "^1.15.5",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.4.27",
    "concurrently": "^9.2.1",
    "electron": "^41.2.0",
    "electron-builder": "^26.8.1",
    "postcss": "^8.5.9",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "tailwindcss": "^4.2.2",
    "typescript": "^6.0.2",
    "vite": "^8.0.7",
    "wait-on": "^9.0.4"
  }
}
